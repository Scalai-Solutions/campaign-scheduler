# MongoDB Connection String (will be overridden by docker-compose environment variable if set)
MONGO_URI=mongodb://admin:password@mongodb:27017/scalai_db?authSource=admin

# Redis URL (will be overridden by docker-compose environment variable if set)
REDIS_URL=redis://redis:6379

# Scheduler instance ID
SCHEDULER_INSTANCE_ID=campaign-scheduler-1

# How long to hold a lease on a task
SCHEDULER_LEASE_TTL_SECONDS=60

# How often to check for tasks
SCHEDULER_POLL_INTERVAL_MS=1000

# Number of tasks to lease at once
DISPATCH_BATCH_SIZE=100

# Retell
RETELL_API_KEY=key_9a35aa79f058c6fa7298a8dd0d25
RETELL_RECONCILE_MAX_AGE_HOURS=12
